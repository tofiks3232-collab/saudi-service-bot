const SUPPORTED_LANGUAGES = ['ar', 'hi', 'en'];

function fill(str, params) {
  if (!params) return str;
  return str.replace(/{{(\w+)}}/g, (_, key) => (params[key] !== undefined ? params[key] : `{{${key}}}`));
}

// t(lang, key, params?) - looks up the string in the requested language,
// falls back to English if missing, and fills in {{placeholders}}.
function t(lang, key, params) {
  const dict = translations[lang] || translations.en;
  const str = dict[key] !== undefined ? dict[key] : translations.en[key];
  if (str === undefined) return key;
  return fill(str, params);
}

module.exports = { t, translations, SUPPORTED_LANGUAGES };
